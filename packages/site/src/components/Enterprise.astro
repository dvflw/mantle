---
const features = [
  { icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`, title: 'Multi-tenancy & RBAC', desc: 'Teams, users, roles (admin / team_owner / operator). API key authentication with hashed storage.' },
  { icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`, title: 'OIDC / SSO', desc: 'Token-sniffing middleware supports API keys and OIDC tokens. Integrate with your existing identity provider.' },
  { icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>`, title: 'Encrypted Credentials', desc: 'AES-256-GCM encryption at rest. Cloud secret backends: AWS Secrets Manager, GCP Secret Manager, Azure Key Vault.' },
  { icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>`, title: 'Audit Trail', desc: 'Every state-changing operation emits an immutable audit event to Postgres. Query with mantle audit.' },
  { icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`, title: 'Prometheus Metrics', desc: 'Workflow execution counts, step durations, connector latencies, active executions gauge. Scrape /metrics in server mode.' },
  { icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>`, title: 'Helm Chart', desc: 'Production-ready Kubernetes deployment. PDB, migration job, startup probes, security contexts, ServiceMonitor.' },
  { icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`, title: 'Rate Limiting', desc: 'Protect external APIs and control execution throughput.' },
  { icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>`, title: 'Data Retention', desc: 'Configure retention policies for execution history and audit events.' },
  { icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>`, title: 'Multi-arch Images', desc: 'amd64 + arm64 Docker images published to GHCR. govulncheck, gosec, and Trivy scanning in CI.' },
];
---
<section class="py-24 lg:py-32 border-t border-outline-variant">
  <div class="mx-auto max-w-[1200px] px-6">
    <h2 class="font-headline text-3xl sm:text-4xl font-bold tracking-tight mb-4" data-animate>Built for Production</h2>
    <p class="text-on-surface-variant mb-12 max-w-2xl" data-animate>Enterprise features ship in the same binary. No upgrade tiers, no feature gates.</p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8" data-animate>
      {features.map((f) => (
        <div class="feature-card flex items-start gap-3 p-4 border border-outline-variant bg-surface-container-low">
          <div class="text-primary shrink-0 mt-0.5" set:html={f.icon} />
          <div>
            <h3 class="font-headline font-semibold text-sm mb-1">{f.title}</h3>
            <p class="text-xs text-on-surface-variant leading-relaxed">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

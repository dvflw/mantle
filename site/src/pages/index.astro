---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Connectors from '../components/Connectors.astro';
import Comparison from '../components/Comparison.astro';
import Enterprise from '../components/Enterprise.astro';
import GetStarted from '../components/GetStarted.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Mantle — Headless AI Workflow Automation">
  <Nav isHome={true} />
  <main id="main-content" class="pb-16 md:pb-0" data-pagefind-ignore>
    <Hero />
    <Features />
    <HowItWorks />
    <Connectors />
    <Comparison />
    <Enterprise />
    <GetStarted />
  </main>
  <Footer />
</Base>

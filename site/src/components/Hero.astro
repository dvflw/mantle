---
---
<section class="relative min-h-screen flex items-center pt-16">
  <div class="mx-auto max-w-[1200px] px-6 py-20 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left column -->
      <div class="flex flex-col gap-6">
        <!-- Version badge -->
        <div class="inline-flex self-start px-3 py-1 border border-outline-variant text-xs font-mono text-on-surface-variant">
          v0.1.0 &mdash; Released March 2026
        </div>

        <!-- Headline -->
        <h1 class="font-headline text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1]">
          Define <span class="inline-flex items-baseline"><span id="typewriter" class="text-primary">AI</span><span class="text-primary animate-blink">_</span></span>
          <br />workflows as YAML.
          <br />Deploy like infrastructure.
        </h1>

        <!-- Subheadline -->
        <p class="text-lg text-on-surface-variant leading-relaxed max-w-lg">
          Single binary. Postgres only. Bring your own keys. 8 connectors, infinite plugins.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 mt-2">
          <a href="https://github.com/dvflw/mantle" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-on-primary font-medium hover:bg-primary-dim transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            View on GitHub
          </a>
          <a href="/docs/getting-started" class="inline-flex items-center gap-2 px-6 py-3 border border-outline-variant text-on-surface font-medium hover:border-on-surface-variant transition-colors">
            Get Started
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="flex flex-wrap gap-6 mt-4 text-xs text-on-surface-variant font-mono">
          <span>8 built-in connectors</span>
          <span>17 example workflows</span>
          <span>Source-available (BSL 1.1)</span>
        </div>
      </div>

      <!-- Right column - Terminal -->
      <div class="relative">
        <div class="dot-grid absolute inset-0 -m-8 opacity-20"></div>
        <div class="relative border border-outline-variant bg-surface-container-low overflow-hidden">
          <!-- Terminal title bar -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-outline-variant bg-surface-container-highest">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
              <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
              <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
            </div>
            <span class="text-xs text-on-surface-variant font-mono ml-2">fetch-and-summarize.yaml</span>
          </div>
          <!-- Terminal content -->
          <div class="p-4 overflow-x-auto">
            <pre class="text-sm font-mono leading-relaxed"><code><span class="text-primary">name</span>: <span class="text-tertiary">fetch-and-summarize</span>
<span class="text-primary">description</span>: <span class="text-tertiary">Fetch data from an API and summarize it</span>

<span class="text-primary">inputs</span>:
  <span class="text-primary">url</span>:
    <span class="text-primary">type</span>: <span class="text-tertiary">string</span>
    <span class="text-primary">description</span>: <span class="text-tertiary">URL to fetch</span>

<span class="text-primary">steps</span>:
  - <span class="text-primary">name</span>: <span class="text-tertiary">fetch-data</span>
    <span class="text-primary">action</span>: <span class="text-secondary">http/request</span>
    <span class="text-primary">params</span>:
      <span class="text-primary">method</span>: <span class="text-tertiary">GET</span>
      <span class="text-primary">url</span>: <span class="text-tertiary">"&#123;&#123; inputs.url &#125;&#125;"</span>

  - <span class="text-primary">name</span>: <span class="text-tertiary">summarize</span>
    <span class="text-primary">action</span>: <span class="text-secondary">ai/completion</span>
    <span class="text-primary">credential</span>: <span class="text-tertiary">my-openai-key</span>
    <span class="text-primary">params</span>:
      <span class="text-primary">model</span>: <span class="text-tertiary">gpt-4o</span>
      <span class="text-primary">prompt</span>: <span class="text-tertiary">"Summarize: &#123;&#123; steps['fetch-data'].output.body &#125;&#125;"</span>
      <span class="text-primary">output_schema</span>:
        <span class="text-primary">type</span>: <span class="text-tertiary">object</span>
        <span class="text-primary">properties</span>:
          <span class="text-primary">summary</span>:
            <span class="text-primary">type</span>: <span class="text-tertiary">string</span>
          <span class="text-primary">key_points</span>:
            <span class="text-primary">type</span>: <span class="text-tertiary">array</span></code></pre>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const words = ['AI', 'Data', 'DevOps', 'Integration', 'Any'];
    const el = document.getElementById('typewriter');
    if (!el) throw new Error('typewriter element not found');

    const HOLD = 2000;
    const TYPE_SPEED = 80;
    const DELETE_SPEED = 50;
    const PAUSE_BEFORE_TYPE = 300;

    let wordIndex = 0;

    async function sleep(ms: number) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }

    // Use zero-width space as empty state to hold line height without adding visible width
    function setText(text: string) {
      el!.textContent = text || '\u200B';
    }

    async function typeWord(word: string) {
      for (let i = 0; i <= word.length; i++) {
        setText(word.slice(0, i));
        await sleep(TYPE_SPEED);
      }
    }

    async function deleteWord(word: string) {
      for (let i = word.length; i >= 0; i--) {
        setText(word.slice(0, i));
        await sleep(DELETE_SPEED);
      }
    }

    async function loop() {
      // Start after initial hold on "AI" (already rendered server-side)
      await sleep(HOLD);

      while (true) {
        // Delete current word
        const currentWord = words[wordIndex];
        await deleteWord(currentWord);
        await sleep(PAUSE_BEFORE_TYPE);

        // Advance to next word
        wordIndex = (wordIndex + 1) % words.length;
        const nextWord = words[wordIndex];

        // Type next word
        await typeWord(nextWord);
        await sleep(HOLD);
      }
    }

    loop();
  </script>
</section>

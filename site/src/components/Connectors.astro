---
const connectors = [
  { icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`, name: 'HTTP', desc: 'REST APIs, webhooks, any HTTP endpoint' },
  { icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`, name: 'AI (OpenAI)', desc: 'Chat completions, structured output, tool use' },
  { icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`, name: 'AI (Bedrock)', desc: 'AWS Bedrock models with region routing' },
  { icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`, name: 'Slack', desc: 'Send messages, read channel history' },
  { icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`, name: 'Email', desc: 'Send via SMTP, plaintext and HTML' },
  { icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/></svg>`, name: 'Postgres', desc: 'Parameterized SQL against external databases' },
  { icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>`, name: 'S3', desc: 'Put, get, list objects (S3-compatible)' },
];
---
<section id="connectors" class="py-24 lg:py-32 border-t border-outline-variant">
  <div class="mx-auto max-w-[1200px] px-6">
    <h2 class="font-headline text-3xl sm:text-4xl font-bold tracking-tight mb-4" data-animate>Built-in Connectors</h2>
    <p class="text-on-surface-variant mb-12 max-w-2xl" data-animate>9 connector actions ship with the binary. HTTP, AI, Slack, Email, Postgres, and S3 &mdash; ready to use.</p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6" data-animate>
      {connectors.map((c) => (
        <div class="flex items-start gap-4 p-4 border border-outline-variant bg-surface-container-low hover:border-outline transition-colors">
          <div class="text-primary shrink-0 mt-0.5" set:html={c.icon} />
          <div>
            <h3 class="font-headline font-semibold text-sm">{c.name}</h3>
            <p class="text-xs text-on-surface-variant mt-1">{c.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Plugin system -->
    <div class="border border-outline-variant bg-surface-container p-6" data-animate>
      <div class="flex items-start gap-4">
        <div class="text-primary shrink-0">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>
        </div>
        <div>
          <h3 class="font-headline font-semibold text-sm mb-1">Plugin System</h3>
          <p class="text-sm text-on-surface-variant">Need something else? Write a plugin. Any executable that reads JSON from stdin and writes JSON to stdout. Python, Rust, Node, Bash &mdash; your call.</p>
        </div>
      </div>
    </div>
  </div>
</section>
